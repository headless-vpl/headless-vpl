{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationDir": "./dist",
    "emitDeclarationOnly": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": "./src/lib/headless-vpl"
  },
  "include": ["src/lib/headless-vpl/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
