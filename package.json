{
  "name": "headless-vpl",
  "version": "0.3.0",
  "type": "module",
  "description": "A headless library for building visual programming languages",
  "module": "./dist/headless-vpl.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/headless-vpl.js",
      "types": "./dist/index.d.ts"
    },
    "./util/mouse": {
      "import": "./dist/util/mouse.js",
      "types": "./dist/util/mouse.d.ts"
    },
    "./util/animate": {
      "import": "./dist/util/animate.js",
      "types": "./dist/util/animate.d.ts"
    },
    "./util/dnd": {
      "import": "./dist/util/dnd.js",
      "types": "./dist/util/dnd.d.ts"
    },
    "./util/collision_detection": {
      "import": "./dist/util/collision_detection.js",
      "types": "./dist/util/collision_detection.d.ts"
    },
    "./util/domController": {
      "import": "./dist/util/domController.js",
      "types": "./dist/util/domController.d.ts"
    }
  },
  "files": ["dist", "LICENSE", "README.md"],
  "license": "MIT",
  "keywords": [
    "visual-programming",
    "vpl",
    "headless",
    "drag-and-drop",
    "node-editor",
    "block-programming"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/headless-vpl/headless-vpl"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:site": "vite build && vitepress build docs-site",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "prepublishOnly": "npm run build:lib",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release": "npm run build:lib && changeset publish",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs-site",
    "docs:build": "vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/cli": "^2.27.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "@vitest/coverage-v8": "^3.0.0",
    "lefthook": "^1.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.7.2",
    "vite": "^6.1.0",
    "vitepress": "^1.6.0",
    "vitest": "^3.0.0"
  }
}
